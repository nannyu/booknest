# ─────────── Server ───────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─────────── Database ───────────
# SQLite 默认；切 Postgres 改 postgres://user:pass@host/db
DATABASE_URL=file:./data/booknest.db

# ─────────── Providers (默认 / 可选) ───────────
ENABLE_OPEN_LIBRARY=true
ENABLE_GOOGLE_BOOKS=true
ENABLE_CROSSREF=false
ENABLE_LOC=false
ENABLE_NLC_OPAC=false
ENABLE_CALIS=false
ENABLE_PDC=false
ENABLE_COMMERCIAL_ISBN=false

# ─────────── Google Books ───────────
# 不填走匿名配额（约 1000/天），填了走 API key 配额
GOOGLE_BOOKS_API_KEY=

# ─────────── 商业 ISBN 服务 ───────────
# 启用后必须填 API key。preset 决定 URL/认证头：
#   isbndb     -> https://api2.isbndb.com/book/{isbn}，Authorization: <key>
#   api_ninjas -> https://api.api-ninjas.com/v1/isbn，X-Api-Key: <key>
# COMMERCIAL_ISBN_API_URL 可选，覆盖默认 endpoint
COMMERCIAL_ISBN_PRESET=isbndb
COMMERCIAL_ISBN_API_KEY=
COMMERCIAL_ISBN_API_URL=

# ─────────── 应用身份（必须）───────────
# 上游 polite usage 要求；改成你自己的项目地址和邮箱
APP_USER_AGENT=BookNest/0.1 (+https://github.com/yourname/booknest; mailto:you@example.com)
APP_CONTACT_EMAIL=you@example.com

# ─────────── 缓存 TTL（天）───────────
# 失败结果短 TTL，避免反复打挂掉的源
FAILURE_CACHE_TTL_DAYS=1

# ─────────── 用户修正 API ───────────
# 每 IP 每分钟最多提交次数
CORRECTIONS_RATE_LIMIT_PER_MIN=10

# ─────────── 封面存储 ───────────
# remote: 直接返回上游 URL（默认）
# local:  下载到 ./data/covers
# s3:     上传到对象存储（v0.2+）
COVER_STORAGE_DRIVER=remote
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
